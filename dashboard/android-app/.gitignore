# Capacitor Android App — ignore generated/compiled files
node_modules/

# Android build outputs (generated by Gradle — do NOT commit)
android/build/
android/app/build/
android/.gradle/
android/local.properties

# Capacitor auto-generated config (synced from capacitor.config.ts)
android/app/src/main/assets/capacitor.config.json
android/app/src/main/assets/capacitor.plugins.json

# Web assets (synced from ../client/dist — do NOT commit the copy)
android/app/src/main/assets/public/

# APK output
*.apk
*.aab
